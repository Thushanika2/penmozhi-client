# Server-side only: backend URL used by Next.js rewrites (/backend -> API)
# Local: http://127.0.0.1:5000
# Vercel: your deployed Flask API, e.g. https://penmozhi-api.onrender.com
API_URL=http://127.0.0.1:5000

# Client-side API base URL. Use /backend so requests are proxied through Next.js
# (avoids CORS; works the same locally and on Vercel).
NEXT_PUBLIC_API_URL=/backend
